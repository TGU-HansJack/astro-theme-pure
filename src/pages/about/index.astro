---
import { Comment } from 'astro-pure/advanced'
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: '爱好' },
  { depth: 2, slug: 'tools', text: '工具' },
  { depth: 2, slug: 'social-networks', text: '社交' },
  { depth: 2, slug: 'about-blog', text: '关于 博客' }
]
---

<PageLayout title='关于' {headings} info='/about'>
  <p>材料人 / 追梦人</p>
  <p>
    你好，我叫Hans J. Han， 来自安徽的天津<Spoiler>2023年</Spoiler>本科生，涉猎广泛：<Spoiler>化学</Spoiler><Spoiler>编程</Spoiler><Spoiler>运维</Spoiler>
  </p>
  <p>目前就读天津工业大学材料专业。</p>
  <p>我的座右铭: 为天地立心，为生民立命，为往圣继绝学，为万世开太平。</p>
  <Button title='赞助我' class='w-fit' href='/projects#sponsorship' style='ahead' />

  {/* general-talk */}
  <h2 id='hobbies'>爱好</h2>
  <ul>
    <li>服务器搭建和运维：时光流·言、Hans J. Hans(Now)</li>
    <li>广泛阅读中外读物：《悉达多》、《尼采诗集》、《毛选》、《传习录》、<Spoiler>武侠小说</Spoiler><Spoiler>历史杂志</Spoiler></li>
    <li>游戏：独爱Minecraft、RTS系列</li>
  </ul>

  {/* tools */}
  <h2 id='tools'>工具</h2>
  <p>以下是我正在使用的一些工具：</p>
  <ToolSection
    class='mb-5'
    title='Design'
    tools={[
      {
        name: 'Photoshop',
        description: 'Picture Editing',
        href: 'https://www.adobe.com/products/photoshop',
        icon: import('@/assets/tools/photoshop.svg?raw')
      },
      {
        name: 'Illustrator',
        description: 'Vector Drawing',
        href: 'https://www.adobe.com/products/illustrator',
        icon: import('@/assets/tools/illustrator.svg?raw')
      },
      {
        name: 'After Effects',
        description: 'Motion Graphics',
        href: 'https://www.adobe.com/products/aftereffects',
        icon: import('@/assets/tools/aftereffects.svg?raw')
      },
      {
        name: 'Premiere Pro',
        description: 'Video Editing',
        href: 'https://www.adobe.com/products/premiere',
        icon: import('@/assets/tools/premiere.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      {
        name: 'Chrome',
        description: 'Broswer',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Firefox',
        description: 'Broswer',
        href: 'https://www.mozilla.org/en-US/firefox',
        icon: import('@/assets/tools/firefox.svg?raw')
      },
      {
        name: 'Notion',
        description: 'Note Taking',
        href: 'https://www.notion.so/',
        icon: import('@/assets/tools/notion.svg?raw')
      },
      {
        name: 'Typora',
        description: 'Markdown Editor',
        href: 'https://typora.io/',
        icon: import('@/assets/tools/typora.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Development'
    tools={[
      {
        name: 'VS Code',
        description: 'IDE',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Neovim',
        description: 'IDE',
        href: 'https://neovim.io/',
        icon: import('@/assets/tools/neovim.svg?raw')
      },
      {
        name: 'Sublime Text',
        description: 'IDE',
        href: 'https://www.sublimetext.com/',
        icon: import('@/assets/tools/sublime.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Environment'
    tools={[
      {
        name: 'Arch Linux',
        description: 'Linux Distribution',
        href: 'https://archlinux.org/',
        icon: import('@/assets/tools/archlinux.svg?raw')
      },
      {
        name: 'Ubuntu 24.04 LTS',
        description: 'Linux Distribution',
        href: 'https://ubuntu.com/',
        icon: import('@/assets/tools/ubuntu.svg?raw')
      },
      {
        name: 'MacOS Sonoma',
        description: 'MacBook Air',
        href: 'https://www.apple.com/macos/',
        icon: import('@/assets/tools/apple.svg?raw')
      },
      {
        name: 'Windows 11',
        description: 'Rog Strix G15',
        href: 'https://news.microsoft.com/windows11-general-availability/',
        icon: import('@/assets/tools/windows11.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>社交</h2>
  <p>
    你可以在以下平台找到我：
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/TGU-HansJack',
        text: 'followers',
        api: 'github/TGU-HansJack'
      }
    ]}
  />

  {/* about-blog */}
  <h2 id='about-blog'>关于 博客</h2>
  <p>Website history:</p>
  <Timeline
    events={[
      {
        date: '2025-04-02',
        content:
          '部署Astro在Vercel，域名hansjack.com'
      },
      {
        date: '2024-06-25',
        content: '建立Typecho博客，域名hansblog.top'
      }
    ]}
  />
  <p>
    本站基于以下项目/服务提供商的资源和技术支持：
  </p>
  <ul>
    <li>域名 <a href='https://www.aliyun.com/' target='_blank'>Alibaba Cloud</a></li>
    <li>
      框架 & 主题: <a href='https://astro.build/' target='_blank'>Astro</a> + <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'>Astro Theme Pure</a
      >
    </li>
    <li>
      站点: <a href='https://vercel.com/' target='_blank'>Vercel</a>
    </li>
    <li>
      CI/CD: <a href='https://vercel.com/workflow' target='_blank'>Vercel Workflow</a>
    </li>
    <!-- <li>Resources speedup: <a href='https://cdn.cbd.int/' target='_blank'>CBD CDN</a></li> -->
    <li>评论系统: <a href='https://waline.js.org' target='_blank'>Waline</a></li>
    <li>
      粉丝数统计: <a href='https://github.com/spencerwooo/substats' target='_blank'
        >Substats</a
      >
    </li>
  </ul>
  <Comment slot='bottom' />
</PageLayout>
